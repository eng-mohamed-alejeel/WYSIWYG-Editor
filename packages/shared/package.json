{
  "name": "@wysiwyg/shared",
  "version": "0.1.0",
  "description": "Shared utilities and constants for WYSIWYG Editor",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wysiwyg/core": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
