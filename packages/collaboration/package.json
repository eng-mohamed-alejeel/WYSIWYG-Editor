{
  "name": "@wysiwyg/collaboration",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time collaborative editing infrastructure for WYSIWYG Editor",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wysiwyg/core": "*",
    "@wysiwyg/editor": "*",
    "yjs": "^13.6.10",
    "y-websocket": "^1.5.0",
    "y-protocols": "^1.0.6",
    "lib0": "^0.2.92",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
