{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@wysiwyg/core/*": ["./packages/core/src/*"],
      "@wysiwyg/editor/*": ["./packages/editor/src/*"],
      "@wysiwyg/renderer/*": ["./packages/renderer/src/*"],
      "@wysiwyg/components/*": ["./packages/components/src/*"],
      "@wysiwyg/exporters/*": ["./packages/exporters/src/*"],
      "@wysiwyg/storage/*": ["./packages/storage/src/*"],
      "@wysiwyg/plugins/*": ["./packages/plugins/src/*"],
      "@wysiwyg/sandbox/*": ["./packages/sandbox/src/*"],
      "@wysiwyg/history/*": ["./packages/history/src/*"],
      "@wysiwyg/ai/*": ["./packages/ai/src/*"],
      "@wysiwyg/shared/*": ["./packages/shared/src/*"]
    }
  },
  "references": [{ "path": "./packages/core" }, { "path": "./packages/shared" }],
  "exclude": ["node_modules", "dist", ".next", "build"]
}
