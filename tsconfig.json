{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@wysiwyg/core/*": ["./packages/core/src/*"],
      "@wysiwyg/editor/*": ["./packages/editor/src/*"],
      "@wysiwyg/renderer/*": ["./packages/renderer/src/*"],
      "@wysiwyg/components/*": ["./packages/components/src/*"],
      "@wysiwyg/exporters/*": ["./packages/exporters/src/*"],
      "@wysiwyg/storage/*": ["./packages/storage/src/*"],
      "@wysiwyg/plugins/*": ["./packages/plugins/src/*"],
      "@wysiwyg/sandbox/*": ["./packages/sandbox/src/*"],
      "@wysiwyg/history/*": ["./packages/history/src/*"],
      "@wysiwyg/ai/*": ["./packages/ai/src/*"],
      "@wysiwyg/shared/*": ["./packages/shared/src/*"]
    }
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/shared" }
  ],
  "exclude": ["node_modules", "dist", ".next", "build"]
}
